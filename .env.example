OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai-proxy.org/v1

# ── LLM 配置（智谱 GLM）──────────────────────
LLM_API_KEY=your-zhipuai-api-key
# 可选模型: glm-4-flash, glm-4, glm-4-plus
LLM_MODEL=glm-4-flash

# ════════════════════════════════════════════════════════════
# 🔄 Reranker 配置（BGE-Reranker）- NEW
# ════════════════════════════════════════════════════════════

# 是否启用 Reranker（默认 true）
ENABLE_RERANKER=true

# Milvus 初始检索结果数（Top-K）
# Reranker 从这些候选中重排序到最终数量
RETRIEVAL_TOP_K=10

# 最终返回结果数（经过 Reranker 重排序后）
RERANK_TOP_K=3

# BGE-Reranker 模型名称
# 可选: BAAI/bge-reranker-v2-m3 (推荐), BAAI/bge-reranker-v2-gemma, BAAI/bge-reranker-large
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Reranker 批处理大小（更大=更快但更多内存）
RERANKER_BATCH_SIZE=32

# 是否使用 FP16 精度（推荐 true，更快）
RERANKER_USE_FP16=true

# Hugging Face 遥测（禁用可消除警告）
HF_HUB_DISABLE_TELEMETRY=1
